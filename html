        <div class="stats-grid">
          <div class="stat-card">
            <svg class="stat-hex" viewBox="0 0 60 60" fill="none" stroke="rgba(0,102,255,0.5)" stroke-width="1"><polygon points="30,2 55,16 55,44 30,58 5,44 5,16"/></svg>
            <div class="stat-inner">
