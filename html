/* ════ FIREBASE ════ */
let fbReady=false;
document.addEventListener('firebase-ready',async()=>{fbReady=true;await loadFirebaseData();});

async function loadFirebaseData(){
  if(!fbReady||!window._db)return;
  try{
    // Load users
    const uSnap=await window._getDocs(window._col(window._db,'users'));
    if(!uSnap.empty){
      const fbUsers=[];uSnap.forEach(d=>fbUsers.push(d.data()));
      const extras=fbUsers.filter(u=>!DEFAULT_USERS.find(d=>d.username===u.username));
      userList=[...DEFAULT_USERS,...extras];
      fbUsers.forEach(fu=>{const loc=userList.find(u=>u.username===fu.username);if(loc&&fu.role)loc.role=fu.role;});
    }
    // Load docs
    const dSnap=await window._getDocs(window._col(window._db,'documents'));
    allDocs=[];dSnap.forEach(d=>allDocs.push({fbId:d.id,...d.data()}));
    allDocs.sort((a,b)=>new Date(b.timestamp)-new Date(a.timestamp));
    updateCounters();
    renderDocs();
    renderEditList();
    renderActivity();
  }catch(e){console.warn('Firebase load:',e);}
}

async function saveDocToFirebase(data){
  if(!fbReady||!window._db)return null;
  const ref=await window._addDoc(window._col(window._db,'documents'),data);
  return ref.id;
}

async function updateDocInFirebase(fbId,data){
  if(!fbReady||!window._db)return;
  await window._updateDoc(window._doc(window._db,'documents',fbId),data);
}

async function deleteDocFromFirebase(fbId){
  if(!fbReady||!window._db)return;
  await window._deleteDoc(window._doc(window._db,'documents',fbId));
}

async function saveUserToFirebase(user){
  if(!fbReady||!window._db)return;
  await window._setDoc(window._doc(window._db,'users',user.username),user);
}

async function saveActivityToFirebase(entry){
  if(!fbReady||!window._db)return;
  await window._addDoc(window._col(window._db,'activity'),entry);
}

function addActivity(text,icon='📝'){
  const entry={text,icon,user:currentUser?.username||'system',time:new Date().toISOString()};
  activityLog.unshift(entry);if(activityLog.length>20)activityLog.pop();
  saveActivityToFirebase(entry);
  renderActivity();
  const el=document.getElementById('s-activity');if(el)el.textContent=activityLog.length;
}

