<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nexus — Access Control Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">

<!-- FIREBASE SDK -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import {
    getFirestore, collection, addDoc, getDocs,
    doc, setDoc, deleteDoc, updateDoc, onSnapshot, query, orderBy, getDoc
  } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "AIzaSyA0GwwBin4iEZaUvEXLTXWPoi1QksY0chQ",
    authDomain: "capstone-30fc0.firebaseapp.com",
    projectId: "capstone-30fc0",
    storageBucket: "capstone-30fc0.firebasestorage.app",
    messagingSenderId: "878417028593",
    appId: "1:878417028593:web:ba932afad532856e579050",
    measurementId: "G-7ZBF302R6H"
  };

  const app = initializeApp(firebaseConfig);
  const db  = getFirestore(app);

  window._db         = db;
  window._col        = collection;
  window._addDoc     = addDoc;
  window._getDocs    = getDocs;
  window._doc        = doc;
  window._setDoc     = setDoc;
  window._deleteDoc  = deleteDoc;
  window._updateDoc  = updateDoc;
  window._onSnapshot = onSnapshot;
  window._query      = query;
  window._orderBy    = orderBy;
  window._getDoc     = getDoc;
  window._fbReady    = true;
  document.dispatchEvent(new Event('firebase-ready'));
</script>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#03030a;--nb:#0066ff;--nb2:#0099ff;--nb3:#33bbff;
  --pu:#7c2dff;--pu2:#a855f7;--cy:#00e5ff;
  --gn:#00ff88;--rd:#ff2d55;--am:#ffb700;
  --glow-b:rgba(0,102,255,.5);--glow-p:rgba(124,45,255,.5);
  --txt:#e8f4ff;--txt2:#8899bb;--txt3:#3a4a6a;
  --f1:'Orbitron',monospace;--f2:'Rajdhani',sans-serif;--f3:'Share Tech Mono',monospace;
  --ease:cubic-bezier(.4,0,.2,1);--spring:cubic-bezier(.34,1.56,.64,1);
}
html,body{height:100%;font-family:var(--f2);color:var(--txt);overflow:hidden;background:var(--ink);-webkit-font-smoothing:antialiased}

/* BACKGROUNDS */
#threeCanvas{position:fixed;inset:0;z-index:0}
#dataCanvas{position:fixed;inset:0;z-index:1;pointer-events:none;opacity:.5}
.scanlines{position:fixed;inset:0;z-index:2;pointer-events:none;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,102,255,.012) 2px,rgba(0,102,255,.012) 4px);animation:scan 8s linear infinite}
@keyframes scan{to{background-position:0 400px}}
.vignette{position:fixed;inset:0;z-index:2;pointer-events:none;background:radial-gradient(ellipse 80% 70% at 50% 50%,transparent 40%,rgba(0,0,10,.65) 100%)}
.hud-corner{position:fixed;z-index:3;pointer-events:none}
.hc-tl{top:0;left:0}.hc-tr{top:0;right:0;transform:scaleX(-1)}.hc-bl{bottom:0;left:0;transform:scaleY(-1)}.hc-br{bottom:0;right:0;transform:scale(-1)}
.cursor-glow{position:fixed;width:280px;height:280px;border-radius:50%;pointer-events:none;z-index:3;transform:translate(-50%,-50%);background:radial-gradient(circle,rgba(0,102,255,.05),transparent 70%);mix-blend-mode:screen}

/* PORTAL */
.portal-ring{position:fixed;top:50%;left:50%;z-index:9998;pointer-events:none;border-radius:50%;border:2px solid var(--nb);transform:translate(-50%,-50%) scale(0);opacity:0}
.portal-ring.expand{animation:pex .9s cubic-bezier(.65,0,.15,1) forwards}
.portal-ring.collapse{animation:pcol .7s cubic-bezier(.65,0,.15,1) forwards}
@keyframes pex{0%{width:0;height:0;opacity:1}100%{width:600vmax;height:600vmax;opacity:0}}
@keyframes pcol{0%{width:600vmax;height:600vmax;opacity:0}40%{opacity:.5}100%{width:0;height:0;opacity:0}}
.portal-fill{position:fixed;inset:0;z-index:9997;pointer-events:none;background:radial-gradient(circle,#0a0a2e,#020210 60%);opacity:0;transition:opacity .3s}
.portal-fill.show{opacity:1}

/* TOAST */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:rgba(5,5,25,.97);backdrop-filter:blur(24px);color:var(--txt);padding:11px 22px;border-radius:2px;font-size:11px;font-weight:600;z-index:9999;transition:transform .45s var(--spring),opacity .45s;opacity:0;white-space:nowrap;border:1px solid rgba(0,102,255,.25);font-family:var(--f3);letter-spacing:1px;clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px))}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1}
.toast.success{border-color:rgba(0,255,136,.3);color:var(--gn)}
.toast.error{border-color:rgba(255,45,85,.3);color:var(--rd)}

/* ════════════════════════════════
   LOGIN
════════════════════════════════ */
.page{position:fixed;inset:0;z-index:10;display:flex;align-items:center;justify-content:center;transition:opacity .8s var(--ease),transform .8s var(--ease)}
.page.hidden{opacity:0;pointer-events:none;transform:scale(.9) translateY(40px)}
.login-wrap{width:440px}
.login-card{background:rgba(5,5,20,.92);backdrop-filter:blur(40px);border:1px solid rgba(0,102,255,.25);border-radius:4px;padding:50px 44px;position:relative;overflow:hidden;animation:cardIn 1.2s var(--spring) both;clip-path:polygon(0 0,calc(100% - 24px) 0,100% 24px,100% 100%,24px 100%,0 calc(100% - 24px))}
.login-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,102,255,.05),transparent 50%,rgba(124,45,255,.05));pointer-events:none}
.card-scan{position:absolute;left:-50%;top:0;width:40%;height:100%;background:linear-gradient(90deg,transparent,rgba(0,102,255,.06),transparent);transform:skewX(-20deg);animation:cscan 5s ease-in-out infinite}
@keyframes cscan{0%{left:-50%}100%{left:150%}}
@keyframes cardIn{0%{opacity:0;transform:perspective(800px) rotateX(25deg) translateY(80px) scale(.85)}100%{opacity:1;transform:none}}
.cc{position:absolute;width:24px;height:24px}.cc-tr{top:0;right:0;border-top:2px solid var(--nb);border-right:2px solid var(--nb)}.cc-bl{bottom:0;left:0;border-bottom:2px solid var(--nb);border-left:2px solid var(--nb)}
.logo-wrap{text-align:center;margin-bottom:38px}
.logo-rings{width:70px;height:70px;margin:0 auto 16px;position:relative;display:flex;align-items:center;justify-content:center}
.logo-ring{position:absolute;border:1px solid;border-radius:50%;animation:rspin 6s linear infinite}
.logo-ring:nth-child(1){inset:0;border-color:rgba(0,102,255,.6)}
.logo-ring:nth-child(2){inset:-10px;border-color:rgba(124,45,255,.4);animation-duration:10s;animation-direction:reverse;border-style:dashed}
.logo-ring:nth-child(3){inset:-20px;border-color:rgba(0,229,255,.2);animation-duration:15s}
@keyframes rspin{to{transform:rotate(360deg)}}
.logo-inner{width:46px;height:46px;background:linear-gradient(135deg,var(--nb),var(--pu));border-radius:10px;display:flex;align-items:center;justify-content:center;box-shadow:0 0 30px var(--glow-b);animation:lpulse 3s ease-in-out infinite}
@keyframes lpulse{0%,100%{box-shadow:0 0 30px var(--glow-b)}50%{box-shadow:0 0 60px var(--glow-b),0 0 0 8px rgba(0,102,255,.06)}}
.logo-inner svg{fill:white;width:22px;height:22px}
.login-title{font-family:var(--f1);font-size:22px;font-weight:900;letter-spacing:5px;color:#fff;text-shadow:0 0 20px var(--nb)}
.login-sub{font-size:11px;color:var(--txt2);letter-spacing:2px;font-family:var(--f3);margin-top:3px}
.field{margin-bottom:16px}
.field label{display:block;font-size:9px;font-weight:600;letter-spacing:2px;color:var(--nb3);margin-bottom:7px;font-family:var(--f3)}
.field-wrap{position:relative}
.field input{width:100%;background:rgba(0,20,60,.4);border:1px solid rgba(0,102,255,.2);border-radius:2px;padding:11px 16px;font-size:13px;font-family:var(--f3);color:var(--txt);outline:none;transition:all .25s;letter-spacing:1px}
.field input:focus{border-color:var(--nb);background:rgba(0,40,100,.3);box-shadow:0 0 0 1px rgba(0,102,255,.3),0 0 20px rgba(0,102,255,.12)}
.field input::placeholder{color:var(--txt3)}
.field-line{position:absolute;bottom:-1px;left:50%;right:50%;height:2px;background:linear-gradient(90deg,var(--nb),var(--cy));transition:left .3s,right .3s}
.field input:focus~.field-line{left:0;right:0;box-shadow:0 0 8px var(--nb)}
.btn-auth{width:100%;margin-top:6px;padding:14px;border:none;border-radius:2px;font-size:11px;font-weight:700;font-family:var(--f1);letter-spacing:3px;cursor:pointer;position:relative;overflow:hidden;background:linear-gradient(90deg,var(--nb),var(--pu),var(--nb));background-size:200%;animation:bshift 3s ease infinite;color:#fff;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));box-shadow:0 0 20px var(--glow-b);transition:transform .2s var(--spring)}
@keyframes bshift{0%{background-position:0}50%{background-position:100%}100%{background-position:0}}
.btn-auth::before{content:'';position:absolute;top:0;left:-100%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);animation:bshim 2.5s ease-in-out infinite}
@keyframes bshim{0%{left:-100%}100%{left:200%}}
.btn-auth:hover{transform:translateY(-2px) scale(1.02)}
.btn-auth:active{transform:scale(.97)}
.login-err{text-align:center;font-size:11px;color:var(--rd);margin-top:10px;min-height:16px;font-family:var(--f3);letter-spacing:1px}
.quick-access{margin-top:24px;padding-top:18px;border-top:1px solid rgba(0,102,255,.1)}
.quick-title{font-size:9px;text-transform:uppercase;letter-spacing:2px;color:var(--txt3);text-align:center;margin-bottom:12px;font-family:var(--f3)}
.quick-chips{display:flex;gap:8px;justify-content:center}
.qchip{padding:6px 16px;border-radius:2px;font-size:10px;font-weight:700;cursor:pointer;border:1px solid transparent;transition:all .3s var(--spring);font-family:var(--f1);letter-spacing:2px;clip-path:polygon(0 0,calc(100% - 7px) 0,100% 7px,100% 100%,7px 100%,0 calc(100% - 7px))}
.qchip:hover{transform:translateY(-3px)}
.qc-a{background:rgba(0,102,255,.08);border-color:rgba(0,102,255,.35);color:var(--nb2)}.qc-a:hover{border-color:var(--nb);box-shadow:0 4px 20px var(--glow-b)}
.qc-e{background:rgba(124,45,255,.08);border-color:rgba(124,45,255,.3);color:var(--pu2)}.qc-e:hover{border-color:var(--pu2);box-shadow:0 4px 20px var(--glow-p)}
.qc-v{background:rgba(255,183,0,.07);border-color:rgba(255,183,0,.25);color:var(--am)}.qc-v:hover{border-color:var(--am);box-shadow:0 4px 20px rgba(255,183,0,.3)}
.login-toggle{text-align:center;margin-top:18px;font-size:12px;color:var(--txt2);font-family:var(--f3)}
.login-toggle a{color:var(--cy);text-decoration:none;margin-left:6px;font-weight:600}
.login-toggle a:hover{color:#fff;text-shadow:0 0 8px var(--cy)}
#nameField{display:none;opacity:0;transform:translateY(-10px);transition:all .3s}

/* ════════════════════════════════
   APP SHELL
════════════════════════════════ */
#appPage{align-items:stretch;flex-direction:column;padding:0}
.topbar{height:56px;flex-shrink:0;background:rgba(3,3,15,.92);backdrop-filter:blur(30px);border-bottom:1px solid rgba(0,102,255,.12);display:flex;align-items:center;padding:0 20px;gap:12px;position:relative;z-index:50}
.topbar::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--nb),var(--cy),var(--pu),transparent);animation:barline 4s linear infinite;background-size:200%}
@keyframes barline{0%{background-position:200%}100%{background-position:-200%}}
.topbar-logo{font-family:var(--f1);font-size:16px;font-weight:900;letter-spacing:5px;background:linear-gradient(90deg,var(--nb),var(--cy));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.tb-status{display:flex;align-items:center;gap:5px;font-size:9px;font-family:var(--f3);color:var(--gn);letter-spacing:1px}
.tb-dot{width:5px;height:5px;border-radius:50%;background:var(--gn);box-shadow:0 0 6px var(--gn);animation:sdot 1.5s ease-in-out infinite}
@keyframes sdot{0%,100%{opacity:1}50%{opacity:.3}}
.tb-sep{flex:1}
.user-chip{display:flex;align-items:center;gap:9px;background:rgba(0,20,60,.5);border:1px solid rgba(0,102,255,.18);border-radius:2px;padding:4px 12px 4px 4px;clip-path:polygon(0 0,calc(100% - 7px) 0,100% 7px,100% 100%,7px 100%,0 calc(100% - 7px))}
.u-av{width:30px;height:30px;border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;font-family:var(--f1);flex-shrink:0}
.u-name{font-size:11px;font-weight:700;font-family:var(--f1);letter-spacing:1px}
.u-sub{font-size:9px;color:var(--txt3);font-family:var(--f3)}
.rpill{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:2px;font-size:8px;font-weight:700;letter-spacing:2px;font-family:var(--f1);clip-path:polygon(0 0,calc(100% - 5px) 0,100% 5px,100% 100%,5px 100%,0 calc(100% - 5px))}
.rpill-dot{width:4px;height:4px;border-radius:50%;animation:rdot 2s ease-in-out infinite}
@keyframes rdot{0%,100%{opacity:1}50%{opacity:.2}}
.rp-admin{background:rgba(0,102,255,.12);color:var(--nb2);border:1px solid rgba(0,102,255,.3)}
.rp-editor{background:rgba(124,45,255,.12);color:var(--pu2);border:1px solid rgba(124,45,255,.25)}
.rp-viewer{background:rgba(255,183,0,.1);color:var(--am);border:1px solid rgba(255,183,0,.2)}
.btn-exit{padding:6px 14px;background:transparent;border:1px solid rgba(255,45,85,.2);border-radius:2px;font-size:9px;font-weight:700;color:rgba(255,45,85,.6);cursor:pointer;font-family:var(--f1);letter-spacing:2px;transition:all .25s var(--spring);clip-path:polygon(0 0,calc(100% - 5px) 0,100% 5px,100% 100%,5px 100%,0 calc(100% - 5px))}
.btn-exit:hover{border-color:var(--rd);color:var(--rd);box-shadow:0 0 12px rgba(255,45,85,.2)}

/* BODY LAYOUT */
.app-body{flex:1;display:flex;overflow:hidden;position:relative;z-index:10}

/* SIDEBAR */
.sidebar{width:200px;flex-shrink:0;background:rgba(3,3,15,.88);backdrop-filter:blur(24px);border-right:1px solid rgba(0,102,255,.08);padding:14px 6px;display:flex;flex-direction:column;gap:1px}
.nav-section-label{font-size:7px;font-weight:700;color:var(--txt3);text-transform:uppercase;letter-spacing:2px;padding:10px 12px 4px;font-family:var(--f3)}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:2px;cursor:pointer;font-size:11px;font-weight:600;color:var(--txt2);transition:all .18s;user-select:none;position:relative;font-family:var(--f2);letter-spacing:.5px}
.nav-item::before{content:'';position:absolute;left:0;top:0;width:2px;height:100%;background:linear-gradient(180deg,var(--nb),var(--cy));transform:scaleY(0);transition:transform .2s;box-shadow:0 0 6px var(--nb)}
.nav-item::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(0,102,255,.07),transparent);opacity:0;transition:opacity .2s}
.nav-item:hover:not(.locked){color:var(--txt)}.nav-item:hover:not(.locked)::after{opacity:1}
.nav-item.active{color:var(--nb2);background:rgba(0,102,255,.05)}.nav-item.active::before{transform:scaleY(1)}.nav-item.active::after{opacity:1}
.nav-item.locked{opacity:.22;cursor:not-allowed}
.nav-icon{width:28px;height:28px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:13px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.04);transition:all .2s;flex-shrink:0}
.nav-item.active .nav-icon{background:rgba(0,102,255,.14);color:var(--nb2);border-color:rgba(0,102,255,.22)}
.nav-badge{margin-left:auto;background:rgba(0,102,255,.15);color:var(--nb2);border:1px solid rgba(0,102,255,.25);padding:1px 6px;border-radius:10px;font-size:9px;font-family:var(--f3);min-width:18px;text-align:center}
.nav-lock{margin-left:auto;opacity:.3}
.sidebar-footer{margin-top:auto;padding:12px 8px;border-top:1px solid rgba(0,102,255,.07)}
.storage-bar-wrap{font-size:9px;color:var(--txt3);font-family:var(--f3);letter-spacing:.5px;margin-bottom:5px}
.storage-bar{height:3px;background:rgba(0,102,255,.12);border-radius:2px;margin-top:4px;overflow:hidden}
.storage-fill{height:100%;background:linear-gradient(90deg,var(--nb),var(--cy));border-radius:2px;transition:width .5s}

/* CONTENT */
.content-area{flex:1;overflow-y:auto;position:relative}
.content-area::-webkit-scrollbar{width:3px}
.content-area::-webkit-scrollbar-thumb{background:rgba(0,102,255,.2);border-radius:2px}

/* PANELS */
.panel{display:none;padding:28px;animation:panelIn .35s var(--ease) both}
.panel.active{display:block}
@keyframes panelIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}

/* SUB-PAGES (Write, Edit pages that replace content) */
.subpage{display:none;position:absolute;inset:0;background:rgba(3,3,12,.97);z-index:20;flex-direction:column;animation:spIn .4s var(--ease) both}
.subpage.open{display:flex}
@keyframes spIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:none}}
.subpage-topbar{height:50px;flex-shrink:0;background:rgba(0,10,30,.9);border-bottom:1px solid rgba(0,102,255,.12);display:flex;align-items:center;padding:0 20px;gap:12px}
.btn-back{display:flex;align-items:center;gap:7px;padding:6px 14px;background:rgba(0,102,255,.08);border:1px solid rgba(0,102,255,.2);border-radius:2px;font-size:10px;font-weight:700;font-family:var(--f1);color:var(--nb2);cursor:pointer;letter-spacing:1px;transition:all .2s;clip-path:polygon(0 0,calc(100% - 6px) 0,100% 6px,100% 100%,6px 100%,0 calc(100% - 6px))}
.btn-back:hover{background:rgba(0,102,255,.15);border-color:rgba(0,102,255,.4)}
.sp-title{font-family:var(--f1);font-size:13px;font-weight:700;letter-spacing:2px;color:var(--txt)}
.sp-title span{color:var(--nb2)}
.subpage-body{flex:1;display:flex;overflow:hidden}

/* PAGE HEADERS */
.ph{margin-bottom:22px;padding-bottom:14px;position:relative}
.ph::after{content:'';position:absolute;bottom:0;left:0;width:50px;height:1px;background:linear-gradient(90deg,var(--nb),transparent)}
.ph-title{font-family:var(--f1);font-size:22px;font-weight:800;letter-spacing:2px;color:#fff;text-shadow:0 0 16px rgba(0,102,255,.25)}
.ph-title span{background:linear-gradient(90deg,var(--nb2),var(--cy));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.ph-desc{font-size:11px;color:var(--txt3);margin-top:4px;font-family:var(--f3);letter-spacing:1px;text-transform:uppercase}

/* CARDS */
.card{background:rgba(5,5,25,.82);border:1px solid rgba(0,102,255,.13);border-radius:4px;position:relative;overflow:hidden;transition:transform .3s var(--spring),border-color .3s,box-shadow .3s;clip-path:polygon(0 0,calc(100% - 14px) 0,100% 14px,100% 100%,14px 100%,0 calc(100% - 14px))}
.card::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:2px;background:linear-gradient(90deg,transparent,var(--nb),var(--cy),transparent);animation:csweep 7s ease-in-out infinite;opacity:.6}
@keyframes csweep{0%{left:-100%}100%{left:200%}}
.card:hover{transform:translateY(-3px);border-color:rgba(0,102,255,.28);box-shadow:0 12px 40px rgba(0,0,0,.4),0 0 24px rgba(0,102,255,.08)}

/* ════════════════════════════════
   DASHBOARD
════════════════════════════════ */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.stat-card{background:rgba(5,5,25,.88);border:1px solid rgba(0,102,255,.1);border-radius:4px;padding:18px;transition:all .3s var(--spring);cursor:default;position:relative;overflow:hidden;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px))}
.stat-card:hover{transform:translateY(-6px);border-color:rgba(0,102,255,.35);box-shadow:0 18px 50px rgba(0,0,0,.4),0 0 30px var(--glow-b)}
.stat-icon{width:36px;height:36px;border-radius:7px;display:flex;align-items:center;justify-content:center;margin-bottom:10px;border:1px solid rgba(0,102,255,.15)}
.stat-val{font-family:var(--f1);font-size:28px;font-weight:900;line-height:1}
.stat-lbl{font-size:9px;color:var(--txt2);margin-top:5px;font-family:var(--f3);letter-spacing:1px;text-transform:uppercase}
.stat-trend{font-size:9px;margin-top:4px;font-family:var(--f3)}
.dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
