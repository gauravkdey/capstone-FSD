/* ═══ NODE ANIMATIONS ═══ */
function animateNodes(t) {
  raycaster.setFromCamera(mouse, camera);
  const hits = raycaster.intersectObjects(interactables);

  let newHover = null;
  if (hits.length > 0) {
    newHover = hits[0].object;
    cEl.classList.add('hover');
    const nd = newHover.parent.userData;
    document.getElementById('tooltip').textContent = nd.label;
    document.getElementById('tooltip').classList.add('show');
  } else {
    cEl.classList.remove('hover');
    document.getElementById('tooltip').classList.remove('show');
  }
  hoveredNode = newHover;

  nodes.forEach((node, i) => {
    const ud = node.userData;
    const isHov = ud.orb === hoveredNode;
    const isSel = ud.selected;

    // Float animation
    const floatY = Math.sin(t * 0.6 + i*1.4) * 0.18;
    node.position.y = ud.baseY + floatY;

    // Rotate core
    ud.orb.rotation.x += ud.rotSpeed;
    ud.orb.rotation.y += ud.rotSpeed * 0.7;
    ud.ring1.rotation.z += 0.006;
    ud.ring2.rotation.x += 0.004;

    // Panel bob
    ud.panel.position.y = 2.4 + Math.sin(t*0.8 + i)*0.06;
    ud.panel.rotation.y = Math.sin(t*0.4 + i)*0.04;

    // Hover effects
    if (isHov || isSel) {
      ud.orb.material.emissiveIntensity = THREE.MathUtils.lerp(ud.orb.material.emissiveIntensity, .6, .1);
      ud.light.intensity = THREE.MathUtils.lerp(ud.light.intensity, 5, .1);
      ud.orb.scale.setScalar(THREE.MathUtils.lerp(ud.orb.scale.x, 1.3, .1));
      node.rotation.y += 0.02;
    } else {
      ud.orb.material.emissiveIntensity = THREE.MathUtils.lerp(ud.orb.material.emissiveIntensity, .2, .08);
      ud.light.intensity = THREE.MathUtils.lerp(ud.light.intensity, 2, .08);
      ud.orb.scale.setScalar(THREE.MathUtils.lerp(ud.orb.scale.x, 1, .08));
      node.rotation.y = THREE.MathUtils.lerp(node.rotation.y, 0, .02);
    }
  });
}

