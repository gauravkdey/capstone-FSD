<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Interactive Study Notes — 3D Learning Space</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Exo+2:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --neon-blue:#00d4ff;--neon-purple:#8b5cf6;--neon-pink:#f472b6;
  --neon-green:#00ff88;--neon-amber:#ffb800;
  --dark:#020a14;--dark2:#040f1e;--dark3:#071525;
  --surface:rgba(0,212,255,.06);--rim:rgba(0,212,255,.15);
  --f1:'Orbitron',monospace;--f2:'Exo 2',sans-serif;
}
html,body{height:100%;overflow:hidden;background:var(--dark);font-family:var(--f2);color:#e0f0ff;cursor:none}

/* CURSOR */
#cursor{position:fixed;width:20px;height:20px;border:1.5px solid var(--neon-blue);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .2s,height .2s,border-color .2s;mix-blend-mode:screen}
#cursor-dot{position:fixed;width:4px;height:4px;background:var(--neon-blue);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);box-shadow:0 0 8px var(--neon-blue)}
#cursor.hover{width:36px;height:36px;border-color:var(--neon-purple)}

/* CANVAS */
#three-canvas{position:fixed;inset:0;z-index:0}

/* HUD OVERLAY */
#hud{position:fixed;inset:0;z-index:10;pointer-events:none}

/* TOP BAR */
.topbar{position:absolute;top:0;left:0;right:0;height:64px;display:flex;align-items:center;padding:0 40px;
  background:linear-gradient(180deg,rgba(2,10,20,.9),transparent);
  border-bottom:1px solid rgba(0,212,255,.08)}
.logo{font-family:var(--f1);font-size:16px;font-weight:700;letter-spacing:3px;
  background:linear-gradient(135deg,var(--neon-blue),var(--neon-purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;
  text-shadow:none;filter:drop-shadow(0 0 12px rgba(0,212,255,.4))}
.logo-sub{font-size:10px;color:rgba(0,212,255,.5);letter-spacing:2px;margin-top:2px;font-family:var(--f2);font-weight:300}
.hud-right{margin-left:auto;display:flex;align-items:center;gap:24px}
.hud-btn{pointer-events:all;font-family:var(--f1);font-size:9px;letter-spacing:2px;padding:8px 18px;
  background:transparent;border:1px solid rgba(0,212,255,.2);border-radius:2px;color:rgba(0,212,255,.7);
  cursor:none;transition:all .25s;position:relative;overflow:hidden}
.hud-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,212,255,.1),rgba(139,92,246,.1));opacity:0;transition:opacity .25s}
.hud-btn:hover::before,.hud-btn.active::before{opacity:1}
.hud-btn:hover,.hud-btn.active{border-color:var(--neon-blue);color:var(--neon-blue);box-shadow:0 0 16px rgba(0,212,255,.2)}
.hud-indicator{display:flex;align-items:center;gap:6px;font-size:9px;letter-spacing:1.5px;color:rgba(0,212,255,.4);font-family:var(--f1)}
.hud-dot{width:5px;height:5px;border-radius:50%;background:var(--neon-green);box-shadow:0 0 8px var(--neon-green);animation:blink 2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* BOTTOM BAR */
.bottombar{position:absolute;bottom:0;left:0;right:0;height:60px;display:flex;align-items:center;padding:0 40px;gap:20px;
  background:linear-gradient(0deg,rgba(2,10,20,.9),transparent);border-top:1px solid rgba(0,212,255,.06)}
.subject-pill{pointer-events:all;cursor:none;display:flex;align-items:center;gap:8px;
  padding:8px 16px;border-radius:30px;font-size:10px;font-weight:600;letter-spacing:1.5px;font-family:var(--f1);
  border:1px solid transparent;transition:all .3s;position:relative;overflow:hidden}
.subject-pill::before{content:'';position:absolute;inset:0;border-radius:30px;opacity:.12;background:currentColor;transition:opacity .2s}
.subject-pill:hover::before,.subject-pill.active::before{opacity:.2}
.subject-pill:hover,.subject-pill.active{box-shadow:0 0 20px currentColor;transform:translateY(-2px)}
.pill-math{color:var(--neon-blue);border-color:rgba(0,212,255,.25)}
.pill-code{color:var(--neon-green);border-color:rgba(0,255,136,.25)}
.pill-science{color:var(--neon-purple);border-color:rgba(139,92,246,.25)}
.pill-physics{color:var(--neon-amber);border-color:rgba(255,184,0,.25)}
.pill-all{color:var(--neon-pink);border-color:rgba(244,114,182,.25)}
.subject-icon{font-size:13px}
.timeline-bar{margin-left:auto;display:flex;align-items:center;gap:10px}
.timeline-step{width:6px;height:6px;border-radius:50%;background:rgba(0,212,255,.2);border:1px solid rgba(0,212,255,.3);transition:all .3s;cursor:none;pointer-events:all}
.timeline-step.done{background:var(--neon-blue);box-shadow:0 0 8px var(--neon-blue)}
.timeline-step.active{background:var(--neon-purple);box-shadow:0 0 12px var(--neon-purple);transform:scale(1.4)}

/* SIDE PANEL */
.side-panel{position:absolute;right:0;top:64px;bottom:60px;width:320px;
  background:linear-gradient(180deg,rgba(4,15,30,.92),rgba(7,21,37,.95));
  border-left:1px solid rgba(0,212,255,.1);backdrop-filter:blur(20px);
  transform:translateX(100%);transition:transform .5s cubic-bezier(.4,0,.2,1);
  display:flex;flex-direction:column;overflow:hidden}
.side-panel.open{transform:translateX(0)}
.panel-header{padding:24px 24px 16px;border-bottom:1px solid rgba(0,212,255,.08)}
.panel-tag{font-size:9px;letter-spacing:2px;font-family:var(--f1);margin-bottom:8px}
.panel-title{font-family:var(--f1);font-size:15px;font-weight:700;line-height:1.3}
.panel-body{flex:1;overflow-y:auto;padding:20px 24px;scrollbar-width:none}
.panel-body::-webkit-scrollbar{display:none}
.note-card{background:rgba(0,212,255,.04);border:1px solid rgba(0,212,255,.1);border-radius:8px;padding:14px;margin-bottom:12px;transition:all .25s;position:relative;overflow:hidden}
.note-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
.note-card.math::before{background:linear-gradient(180deg,var(--neon-blue),var(--neon-purple))}
.note-card.code::before{background:linear-gradient(180deg,var(--neon-green),#00b8d4)}
.note-card.science::before{background:linear-gradient(180deg,var(--neon-purple),var(--neon-pink))}
.note-card.physics::before{background:linear-gradient(180deg,var(--neon-amber),var(--neon-pink))}
.note-card:hover{background:rgba(0,212,255,.08);transform:translateX(-4px)}
.note-label{font-size:9px;letter-spacing:1.5px;font-family:var(--f1);opacity:.6;margin-bottom:6px}
.note-content{font-size:12px;line-height:1.7;color:rgba(224,240,255,.8)}
.note-formula{font-family:'Courier New',monospace;font-size:11px;background:rgba(0,212,255,.08);padding:8px 10px;border-radius:4px;margin:8px 0;color:var(--neon-blue);letter-spacing:.5px;border:1px solid rgba(0,212,255,.1)}
.note-highlight{background:rgba(139,92,246,.15);border:1px solid rgba(139,92,246,.25);border-radius:3px;padding:0 4px;color:var(--neon-purple)}
.close-panel{position:absolute;top:16px;right:16px;width:28px;height:28px;border:1px solid rgba(0,212,255,.2);border-radius:2px;display:flex;align-items:center;justify-content:center;cursor:none;pointer-events:all;transition:all .2s;font-size:12px;color:rgba(0,212,255,.6)}
.close-panel:hover{border-color:var(--neon-blue);color:var(--neon-blue);background:rgba(0,212,255,.08)}

/* INTRO OVERLAY */
#intro{position:fixed;inset:0;z-index:100;display:flex;align-items:center;justify-content:center;flex-direction:column;
  background:radial-gradient(ellipse at 50% 50%,#0a1628,#020a14);
  transition:opacity 1.5s ease,transform 1.5s ease}
#intro.gone{opacity:0;pointer-events:none;transform:scale(1.05)}
.intro-title{font-family:var(--f1);font-size:clamp(28px,5vw,56px);font-weight:900;text-align:center;line-height:1.1;letter-spacing:-1px;
  background:linear-gradient(135deg,#fff 0%,var(--neon-blue) 40%,var(--neon-purple) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;
  animation:title-in 1.2s cubic-bezier(.34,1.56,.64,1) both}
@keyframes title-in{from{opacity:0;transform:translateY(40px) scale(.9)}to{opacity:1;transform:translateY(0) scale(1)}}
.intro-sub{font-size:13px;letter-spacing:4px;color:rgba(0,212,255,.5);margin-top:16px;text-transform:uppercase;font-family:var(--f2);font-weight:300;animation:fade-in 1.5s .4s both}
@keyframes fade-in{from{opacity:0}to{opacity:1}}
.intro-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(0,212,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,.04) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 30%,transparent)}
.intro-btn{margin-top:48px;font-family:var(--f1);font-size:11px;letter-spacing:3px;padding:16px 40px;
  background:transparent;border:1px solid var(--neon-blue);color:var(--neon-blue);cursor:none;pointer-events:all;
  animation:fade-in 1s 1s both;position:relative;overflow:hidden;transition:all .3s}
.intro-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,212,255,.15),rgba(139,92,246,.15));opacity:0;transition:opacity .3s}
.intro-btn:hover::before{opacity:1}
.intro-btn:hover{box-shadow:0 0 30px rgba(0,212,255,.3);transform:translateY(-2px)}
.scan-lines{position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,212,255,.015) 2px,rgba(0,212,255,.015) 4px);pointer-events:none;animation:scan-move 8s linear infinite}
@keyframes scan-move{from{background-position:0 0}to{background-position:0 80px}}

/* LABEL TAGS floating over 3D */
.label-tag{position:absolute;pointer-events:none;transform:translate(-50%,-50%);
  font-family:var(--f1);font-size:8px;letter-spacing:2px;padding:4px 10px;
  border:1px solid;border-radius:2px;white-space:nowrap;transition:opacity .5s;
  text-shadow:0 0 10px currentColor}

/* STATUS */
.status-bar{position:absolute;left:40px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:8px}
.status-item{font-size:8px;letter-spacing:1.5px;color:rgba(0,212,255,.3);font-family:var(--f1);display:flex;align-items:center;gap:6px}
.status-bar-inner{width:60px;height:1px;background:rgba(0,212,255,.1);position:relative;overflow:hidden}
.status-bar-fill{height:100%;background:linear-gradient(90deg,var(--neon-blue),var(--neon-purple));animation:fill-anim 3s ease-in-out infinite alternate}
@keyframes fill-anim{from{width:20%}to{width:100%}}

/* TOOLTIP */
.tooltip{position:fixed;pointer-events:none;z-index:50;
  background:rgba(4,15,30,.92);border:1px solid rgba(0,212,255,.2);
  padding:8px 14px;border-radius:4px;font-size:11px;color:var(--neon-blue);font-family:var(--f1);letter-spacing:1px;
  opacity:0;transition:opacity .2s;backdrop-filter:blur(10px);
  box-shadow:0 0 20px rgba(0,212,255,.15)}
.tooltip.show{opacity:1}

/* LOADING */
#loader{position:fixed;inset:0;z-index:200;background:var(--dark);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px}
.loader-ring{width:60px;height:60px;border:2px solid rgba(0,212,255,.1);border-top-color:var(--neon-blue);border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loader-text{font-family:var(--f1);font-size:9px;letter-spacing:3px;color:rgba(0,212,255,.5)}
#loader.gone{opacity:0;pointer-events:none;transition:opacity .5s}
</style>
</head>
<body>

<div id="loader"><div class="loader-ring"></div><div class="loader-text">INITIALIZING STUDY SPACE</div></div>

<canvas id="three-canvas"></canvas>
<div id="cursor"></div>
<div id="cursor-dot"></div>
<div class="tooltip" id="tooltip"></div>

<!-- INTRO -->
<div id="intro">
  <div class="intro-grid"></div>
  <div class="scan-lines"></div>
  <div class="intro-title">Interactive<br>Study Notes</div>
  <div class="intro-sub">3D Learning Environment · v2.0</div>
  <button class="intro-btn" id="enterBtn">ENTER SPACE ⟶</button>
</div>

<!-- HUD -->
<div id="hud">
  <div class="topbar">
    <div>
      <div class="logo">STUDY·OS</div>
      <div class="logo-sub">NEURAL LEARNING INTERFACE</div>
    </div>
    <div class="hud-right">
      <div class="hud-indicator"><div class="hud-dot"></div>LIVE SESSION</div>
      <button class="hud-btn active" id="btnAutoRotate">AUTO·CAM</button>
      <button class="hud-btn" id="btnReset">RESET VIEW</button>
    </div>
  </div>

  <div class="status-bar">
    <div class="status-item">FOCUS<div class="status-bar-inner"><div class="status-bar-fill"></div></div></div>
    <div class="status-item">SYNC<div class="status-bar-inner"><div class="status-bar-fill" style="animation-delay:.5s"></div></div></div>
    <div class="status-item">DEPTH<div class="status-bar-inner"><div class="status-bar-fill" style="animation-delay:1s"></div></div></div>
  </div>

  <!-- SIDE PANEL -->
  <div class="side-panel" id="sidePanel">
    <button class="close-panel" id="closePanel">✕</button>
    <div class="panel-header">
      <div class="panel-tag" id="panelTag">SUBJECT</div>
      <div class="panel-title" id="panelTitle">Select a node</div>
    </div>
    <div class="panel-body" id="panelBody"></div>
  </div>

  <div class="bottombar">
    <div class="subject-pill pill-all active" data-subject="all" id="pillAll">
      <span class="subject-icon">⬡</span>ALL SUBJECTS
    </div>
    <div class="subject-pill pill-math" data-subject="math" id="pillMath">
      <span class="subject-icon">∑</span>MATHEMATICS
    </div>
    <div class="subject-pill pill-code" data-subject="code" id="pillCode">
      <span class="subject-icon">⟨⟩</span>PROGRAMMING
    </div>
    <div class="subject-pill pill-science" data-subject="science" id="pillScience">
      <span class="subject-icon">⬡</span>SCIENCE
    </div>
    <div class="subject-pill pill-physics" data-subject="physics" id="pillPhysics">
      <span class="subject-icon">⚛</span>PHYSICS
    </div>
    <div class="timeline-bar">
      <div class="timeline-step done" data-step="0"></div>
      <div class="timeline-step active" data-step="1"></div>
      <div class="timeline-step" data-step="2"></div>
      <div class="timeline-step" data-step="3"></div>
      <div class="timeline-step" data-step="4"></div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
/* ═══════════════════════════════════════════════════
   INTERACTIVE STUDY NOTES — 3D ENGINE
═══════════════════════════════════════════════════ */

const canvas = document.getElementById('three-canvas');
const W = window.innerWidth, H = window.innerHeight;

/* ── RENDERER ── */
const renderer = new THREE.WebGLRenderer({canvas, antialias:true, alpha:true});
renderer.setSize(W, H);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.2;

/* ── SCENE ── */
const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2(0x020a14, 0.035);

/* ── CAMERA ── */
const camera = new THREE.PerspectiveCamera(55, W/H, 0.1, 200);
camera.position.set(0, 6, 16);
camera.lookAt(0, 0, 0);

/* ── CLOCK ── */
const clock = new THREE.Clock();
let autoRotate = true;
let camAngle = 0;
let camRadius = 16;
let camHeight = 6;
let targetCamAngle = 0;
let targetRadius = 16;
let targetHeight = 6;

/* ── COLORS ── */
const C = {
  blue: 0x00d4ff, purple: 0x8b5cf6, pink: 0xf472b6,
  green: 0x00ff88, amber: 0xffb800, dark: 0x020a14,
  white: 0xffffff, dimBlue: 0x0a3050
};

/* ═══ LIGHTS ═══ */
const ambLight = new THREE.AmbientLight(0x050a20, 0.8);
scene.add(ambLight);

const dirLight = new THREE.DirectionalLight(0x00d4ff, 1.5);
dirLight.position.set(10, 15, 10);
dirLight.castShadow = true;
dirLight.shadow.mapSize.width = 2048;
dirLight.shadow.mapSize.height = 2048;
dirLight.shadow.camera.near = 0.1;
dirLight.shadow.camera.far = 60;
dirLight.shadow.camera.left = -20;
dirLight.shadow.camera.right = 20;
dirLight.shadow.camera.top = 20;
dirLight.shadow.camera.bottom = -20;
scene.add(dirLight);

const ptLight1 = new THREE.PointLight(0x8b5cf6, 3, 20);
ptLight1.position.set(-8, 4, -4);
scene.add(ptLight1);

const ptLight2 = new THREE.PointLight(0x00d4ff, 2, 18);
ptLight2.position.set(8, 3, 2);
scene.add(ptLight2);

const ptLight3 = new THREE.PointLight(0xf472b6, 1.5, 12);
ptLight3.position.set(0, -2, 8);
scene.add(ptLight3);

/* ═══ FLOOR / DESK ═══ */
function buildDesk() {
  const g = new THREE.Group();

  // Desk surface
  const deskGeo = new THREE.BoxGeometry(24, 0.15, 10);
  const deskMat = new THREE.MeshStandardMaterial({
    color: 0x04111f, roughness: 0.1, metalness: 0.8,
    envMapIntensity: 1.2
  });
  const desk = new THREE.Mesh(deskGeo, deskMat);
  desk.position.y = -2;
  desk.receiveShadow = true;
  g.add(desk);

  // Desk edge glow strip
  const edgeGeo = new THREE.BoxGeometry(24, 0.02, 0.04);
  const edgeMat = new THREE.MeshBasicMaterial({color: 0x00d4ff});
  const edge1 = new THREE.Mesh(edgeGeo, edgeMat);
  edge1.position.set(0, -1.93, 5.08);
  g.add(edge1);
  const edge2 = edge1.clone();
  edge2.position.z = -4.98;
  g.add(edge2);

  // Grid lines on desk
  for (let i = -11; i <= 11; i += 2) {
    const lineGeo = new THREE.BoxGeometry(0.01, 0.001, 10);
    const lineMat = new THREE.MeshBasicMaterial({color: 0x0a2040, transparent:true, opacity:.4});
    const line = new THREE.Mesh(lineGeo, lineMat);
    line.position.set(i, -1.92, 0);
    g.add(line);
  }
  for (let i = -4; i <= 4; i += 2) {
    const lineGeo = new THREE.BoxGeometry(24, 0.001, 0.01);
    const lineMat = new THREE.MeshBasicMaterial({color: 0x0a2040, transparent:true, opacity:.4});
    const line = new THREE.Mesh(lineGeo, lineMat);
    line.position.set(0, -1.92, i);
    g.add(line);
  }

  // Legs
  const legGeo = new THREE.CylinderGeometry(0.08, 0.06, 3.5, 8);
  const legMat = new THREE.MeshStandardMaterial({color:0x0a1a2e, roughness:.3, metalness:.9});
  [[-10.5,-4], [-10.5,4], [10.5,-4], [10.5,4]].forEach(([x,z]) => {
    const leg = new THREE.Mesh(legGeo, legMat);
    leg.position.set(x, -3.8, z);
    g.add(leg);
  });

  // Floor reflection plane
  const floorGeo = new THREE.PlaneGeometry(80, 80);
  const floorMat = new THREE.MeshStandardMaterial({
    color:0x010810, roughness:.05, metalness:.9, transparent:true, opacity:.7
  });
  const floor = new THREE.Mesh(floorGeo, floorMat);
  floor.rotation.x = -Math.PI / 2;
  floor.position.y = -5.7;
  floor.receiveShadow = true;
  g.add(floor);

  scene.add(g);
  return g;
}
buildDesk();

/* ═══ PARTICLES ═══ */
function buildParticles() {
  const count = 600;
  const positions = new Float32Array(count * 3);
  const colors = new Float32Array(count * 3);
  const sizes = new Float32Array(count);
  const baseColors = [
    new THREE.Color(0x00d4ff), new THREE.Color(0x8b5cf6),
    new THREE.Color(0xf472b6), new THREE.Color(0x00ff88)
  ];
  for (let i = 0; i < count; i++) {
    positions[i*3] = (Math.random()-0.5)*60;
    positions[i*3+1] = (Math.random()-0.5)*30 + 2;
    positions[i*3+2] = (Math.random()-0.5)*40;
    const c = baseColors[Math.floor(Math.random()*baseColors.length)];
    colors[i*3] = c.r; colors[i*3+1] = c.g; colors[i*3+2] = c.b;
    sizes[i] = Math.random() * 2.5 + 0.5;
  }
  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));
  geo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
  const mat = new THREE.PointsMaterial({size:.08, vertexColors:true, transparent:true, opacity:.6, sizeAttenuation:true});
  const pts = new THREE.Points(geo, mat);
  scene.add(pts);
  return pts;
}
const particles = buildParticles();

/* ═══ HOLOGRAPHIC PANEL ═══ */
function makeHoloPanelGeo(w, h, depth=0.04) {
  return new THREE.BoxGeometry(w, h, depth);
}

function makeHoloPanelMat(color, opacity=0.85) {
  return new THREE.MeshStandardMaterial({
    color, roughness:0.05, metalness:0.3, transparent:true, opacity,
    emissive: color, emissiveIntensity:0.15
  });
}

function makeGlowEdge(w, h, color) {
  const g = new THREE.Group();
  const mat = new THREE.MeshBasicMaterial({color, transparent:true, opacity:.8});
  // Top/bottom edges
  [[w,0.02,0.01,0,h/2,0],[w,0.02,0.01,0,-h/2,0]].forEach(([gw,gh,gd,x,y,z])=>{
    const m = new THREE.Mesh(new THREE.BoxGeometry(gw,gh,gd),mat);
