/* ════ AUTH ════ */
let isSignup=false;
function toggleMode(e){
  e.preventDefault();isSignup=!isSignup;
  const nf=document.getElementById('nameField');
  const btn=document.getElementById('authBtn');
  document.getElementById('loginErr').textContent='';
  if(isSignup){
    nf.style.display='block';void nf.offsetWidth;nf.style.opacity='1';nf.style.transform='translateY(0)';
    btn.textContent='[ CREATE ACCOUNT ]';
    document.getElementById('toggleTxt').textContent='Already registered?';
    document.getElementById('toggleLink').textContent='Sign In';
    document.getElementById('loginTitle').textContent='REGISTER';
    document.getElementById('loginSub').textContent='CREATE VIEWER ACCOUNT';
  }else{
    nf.style.opacity='0';nf.style.transform='translateY(-10px)';
    setTimeout(()=>{if(!isSignup)nf.style.display='none';},300);
    btn.textContent='[ AUTHENTICATE ]';
    document.getElementById('toggleTxt').textContent='New to the network?';
    document.getElementById('toggleLink').textContent='Register';
    document.getElementById('loginTitle').textContent='NEXUS';
    document.getElementById('loginSub').textContent='ACCESS CONTROL PLATFORM';
  }
}

function handleAuth(){isSignup?doSignup():doLogin();}

async function doSignup(){
  const n=document.getElementById('fName').value.trim();
  const u=document.getElementById('fUser').value.trim().toLowerCase();
  const p=document.getElementById('fPass').value;
  const err=document.getElementById('loginErr');
  if(!n||!u||!p){err.textContent='> ERROR: MISSING_FIELDS';return;}
  if(userList.some(x=>x.username===u)){err.textContent='> ERROR: USER_ID_EXISTS';return;}
  const parts=n.split(' ').filter(x=>x);
  let ini=parts[0][0].toUpperCase()+(parts[1]?parts[1][0].toUpperCase():n[1]?.toUpperCase()||'');
  const clrs=[{color:'#0099ff',bg:'rgba(0,102,255,.18)'},{color:'#a855f7',bg:'rgba(124,45,255,.18)'},{color:'#00e5ff',bg:'rgba(0,229,255,.15)'}];
  const c=clrs[Math.floor(Math.random()*3)];
  const nu={id:Math.max(...userList.map(x=>x.id))+1,username:u,password:p,name:n,initials:ini,role:'viewer',color:c.color,bg:c.bg};
  userList.push(nu);
  await saveUserToFirebase(nu);
  currentUser=nu;err.textContent='';triggerPortal();
}

function doLogin(){
  const u=document.getElementById('fUser').value.trim().toLowerCase();
  const p=document.getElementById('fPass').value;
  const err=document.getElementById('loginErr');
  // Check Firebase-synced users too
  const found=userList.find(x=>x.username===u&&x.password===p);
  if(!found){err.textContent='> ERROR: AUTH_REJECTED';return;}
  err.textContent='';currentUser=found;triggerPortal();
}

function quickLogin(u,p){document.getElementById('fUser').value=u;document.getElementById('fPass').value=p;setTimeout(doLogin,100);}

document.getElementById('fPass').addEventListener('keydown',e=>{if(e.key==='Enter')handleAuth();});

/* ════ PORTAL ════ */
function triggerPortal(){
  const ring=document.getElementById('portalRing'),fill=document.getElementById('portalFill');
  ring.classList.remove('collapse');ring.classList.add('expand');
  setTimeout(()=>{
    fill.classList.add('show');
    setTimeout(()=>{
      buildApp();
      document.getElementById('loginPage').classList.add('hidden');
      document.getElementById('appPage').classList.remove('hidden');
      ring.classList.remove('expand');ring.classList.add('collapse');
      setTimeout(()=>{fill.classList.remove('show');ring.classList.remove('collapse');},700);
    },200);
  },500);
}

function portalOut(cb){
  const ring=document.getElementById('portalRing'),fill=document.getElementById('portalFill');
  ring.classList.remove('collapse');ring.classList.add('expand');
  setTimeout(()=>{fill.classList.add('show');setTimeout(()=>{cb();ring.classList.remove('expand');ring.classList.add('collapse');setTimeout(()=>{fill.classList.remove('show');ring.classList.remove('collapse');},700);},200);},500);
}

function doLogout(){
  portalOut(()=>{
    currentUser=null;
    document.getElementById('appPage').classList.add('hidden');
    document.getElementById('loginPage').classList.remove('hidden');
    ['fName','fUser','fPass'].forEach(id=>document.getElementById(id).value='');
