/* SAVE WRITE */
async function saveWrite(){
  const title=document.getElementById('w-title').value.trim()||'Untitled Document';
  const desc=document.getElementById('w-desc').value.trim();
  const body=document.getElementById('w-editor').innerHTML.trim();
  const bodyText=document.getElementById('w-editor').innerText.trim();
  if(!bodyText){toast('Nothing to save!','error');return;}
  const st=document.getElementById('ws-status');
  st.textContent='Saving...';st.className='save-status saving';
  const data={title,desc,tag:selectedTag,body,bodyText,author:currentUser.username,authorName:currentUser.name,type:'write',timestamp:new Date().toISOString()};
  try{
    const fbId=await saveDocToFirebase(data);
    allDocs.unshift({fbId,...data});
    updateCounters();renderDocs();renderEditList();
    st.textContent='✓ Saved to Firebase';st.className='save-status saved';
    toast('Document saved to Firebase!','success');
    addActivity(`<strong>${currentUser.name}</strong> wrote "<em>${title}</em>"`,'✍️');
    // Reset
    setTimeout(()=>{st.textContent='Ready';st.className='save-status';},3000);
    document.getElementById('w-title').value='';
    document.getElementById('w-desc').value='';
    document.getElementById('w-editor').innerHTML='';
    document.querySelectorAll('.es-tag').forEach(t=>t.classList.remove('sel'));
    selectedTag='';
    updateWriteStats();
  }catch(e){st.textContent='Save failed';st.className='save-status';toast('Firebase error: '+e.message,'error');}
}

function clearWrite(){
  if(confirm('Clear all content?')){
    document.getElementById('w-editor').innerHTML='';
    document.getElementById('w-title').value='';
    document.getElementById('w-desc').value='';
    updateWriteStats();
  }
}

