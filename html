  document.getElementById('permList').innerHTML=defs.map((d,i)=>`<li class="perm-item" style="animation-delay:${i*.07}s"><div class="perm-dot" style="background:${p[d.k]?'var(--gn)':'var(--txt3)'};box-shadow:${p[d.k]?'0 0 6px var(--gn)':'none'}"></div><span class="perm-lbl">${d.l}</span><span class="${p[d.k]?'perm-granted':'perm-denied'}">${p[d.k]?'✓ GRANTED':'DENIED'}</span></li>`).join('');
  // Matrix
  document.getElementById('matrixGrid').innerHTML=[
    {r:'admin',c:'mx-admin',cl:'var(--nb2)',ps:['view','write','edit','assign']},
    {r:'editor',c:'mx-editor',cl:'var(--pu2)',ps:['view','write']},
    {r:'viewer',c:'mx-viewer',cl:'var(--am)',ps:['view']},
  ].map(m=>`<div class="mx-card ${m.c}"><div class="mx-rname" style="color:${m.cl}">${m.r.toUpperCase()}</div>${defs.map(d=>`<div class="mx-perm"><span class="${m.ps.includes(d.k)?'mx-check':'mx-cross'}">${m.ps.includes(d.k)?'✓':'—'}</span> ${d.l.split(' ')[0]}</div>`).join('')}</div>`).join('');
