}, 4000);

/* ═══ MAIN LOOP ═══ */
function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();

  // Cursor lerp
  cx2 = cx2 + (mx - cx2) * 0.14;
  cy2 = cy2 + (my - cy2) * 0.14;
  cEl.style.left = cx2+'px';
  cEl.style.top = cy2+'px';

  animateCamera(t);
  animateNodes(t);
  animateLiveGraph(t);
  animateWaveform(t);
  animateParticles(t);

  // Lights pulse
  ptLight1.intensity = 3 + Math.sin(t*1.2)*1;
  ptLight2.intensity = 2 + Math.cos(t*.9)*0.8;
  ptLight3.intensity = 1.5 + Math.sin(t*1.5)*.5;

  renderer.render(scene, camera);
}

/* ═══ INTRO ═══ */
document.getElementById('enterBtn').addEventListener('click', () => {
  document.getElementById('intro').classList.add('gone');
});

/* ═══ LOAD ═══ */
setTimeout(() => {
  document.getElementById('loader').classList.add('gone');
  animate();
}, 1200);

/* ═══ RESIZE ═══ */
window.addEventListener('resize', () => {
  const w = window.innerWidth, h = window.innerHeight;
  camera.aspect = w/h;
  camera.updateProjectionMatrix();
  renderer.setSize(w, h);
});
</script>
