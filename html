function handleAuth(){isSignup?doSignup():doLogin()}

function doSignup(){
  const n=document.getElementById('loginName').value.trim();
  const u=document.getElementById('loginUser').value.trim().toLowerCase();
  const p=document.getElementById('loginPass').value;
  const err=document.getElementById('loginErr');
  if(!n||!u||!p){err.textContent='> ERROR: MISSING_FIELDS';return}
  if(userList.some(x=>x.username===u)){err.textContent='> ERROR: USER_ID_EXISTS';return}
  const parts=n.split(' ').filter(x=>x);
  let ini=parts[0].charAt(0).toUpperCase();
  if(parts.length>1)ini+=parts[parts.length-1].charAt(0).toUpperCase();
  else if(n.length>1)ini+=n.charAt(1).toUpperCase();
  const clrs=[{color:'#0099ff',bg:'rgba(0,102,255,.18)'},{color:'#a855f7',bg:'rgba(124,45,255,.18)'},{color:'#00e5ff',bg:'rgba(0,229,255,.15)'}];
  const c=clrs[Math.floor(Math.random()*clrs.length)];
  const nu={id:Math.max(...userList.map(x=>x.id))+1,username:u,password:p,name:n,initials:ini,role:'viewer',color:c.color,bg:c.bg};
  userList.push(nu);currentUser=nu;err.textContent='';triggerPortal();
}

function doLogin(){
  const u=document.getElementById('loginUser').value.trim().toLowerCase();
  const p=document.getElementById('loginPass').value;
  const err=document.getElementById('loginErr');
  const found=userList.find(x=>x.username===u&&x.password===p);
  if(!found){err.textContent='> ERROR: AUTH_REJECTED';return}
  err.textContent='';currentUser=found;triggerPortal();
}

function quickLogin(u,p){
  document.getElementById('loginUser').value=u;
  document.getElementById('loginPass').value=p;
  setTimeout(doLogin,120);
}

/* PORTAL TRANSITION */
function triggerPortal(cb){
  const ring=document.getElementById('portalRing');
  const fill=document.getElementById('portalFill');
  ring.classList.remove('collapse');ring.classList.add('expand');
  setTimeout(()=>{fill.classList.add('show');
    setTimeout(()=>{
      buildApp();
      document.getElementById('loginPage').classList.add('hidden');
      document.getElementById('appPage').classList.remove('hidden');
      ring.classList.remove('expand');ring.classList.add('collapse');
      setTimeout(()=>{fill.classList.remove('show');ring.classList.remove('collapse')},700);
    },200);
  },500);
}

function portalOut(cb){
  const ring=document.getElementById('portalRing');
  const fill=document.getElementById('portalFill');
  ring.classList.remove('collapse');ring.classList.add('expand');
  setTimeout(()=>{fill.classList.add('show');
    setTimeout(()=>{
      cb();
      ring.classList.remove('expand');ring.classList.add('collapse');
      setTimeout(()=>{fill.classList.remove('show');ring.classList.remove('collapse')},700);
    },200);
  },500);
}

document.getElementById('loginPass').addEventListener('keydown',e=>{if(e.key==='Enter')handleAuth()});

