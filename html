  const waveMat = new THREE.LineBasicMaterial({color:C.purple, linewidth:2});
  const waveLine = new THREE.Line(waveGeo, waveMat);
  g.add(waveLine);

  g.userData.waveLine = waveLine;
  g.userData.wavePositions = positions;
  scene.add(g);
  return g;
}
