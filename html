  const list=document.getElementById('editDocList');
  if(!list)return;
  const docs=filter?allDocs.filter(d=>d.title.toLowerCase().includes(filter.toLowerCase())):allDocs;
  if(!docs.length){list.innerHTML='<div style="padding:16px;color:var(--txt3);font-size:11px;font-family:var(--f3)">No documents yet.</div>';return;}
  list.innerHTML=docs.map(d=>`
    <div class="doc-list-item ${d.fbId===currentEditDocId?'sel':''}" onclick="loadDocForEdit('${d.fbId}')">
      <div class="dli-title">${d.title||'Untitled'}</div>
      <div class="dli-meta">By ${d.authorName||d.author} · ${fmtDate(d.timestamp)}</div>
      <div class="dli-del" onclick="event.stopPropagation();quickDelete('${d.fbId}')">✕</div>
    </div>`).join('');
}

function filterEditList(v){renderEditList(v);}

function loadDocForEdit(fbId){
  const doc=allDocs.find(d=>d.fbId===fbId);
  if(!doc)return;
  currentEditDocId=fbId;
  const ed=document.getElementById('e-editor');
  ed.innerHTML=doc.body||doc.bodyText||'';
  ed.contentEditable='true';
  const sb=document.getElementById('e-save-btn');if(sb)sb.disabled=false;
  const db=document.getElementById('e-del-btn');if(db)db.disabled=false;
  const dn=document.getElementById('e-doc-name');if(dn)dn.textContent=doc.title||'Untitled';
  const em=document.getElementById('e-modified');if(em)em.textContent='Not modified';
  const es=document.getElementById('es-status');if(es){es.textContent='Editing: '+doc.title;es.className='save-status';}
  renderEditList();
  updateEditStats();
}

let editModified=false;
function markEdited(){
  editModified=true;
  const em=document.getElementById('e-modified');if(em)em.textContent='Modified — unsaved';
}

async function saveEdit(){
  if(!currentEditDocId){toast('No document selected','error');return;}
  const ed=document.getElementById('e-editor');
  const body=ed.innerHTML.trim();
  const bodyText=ed.innerText.trim();
  const es=document.getElementById('es-status');
  es.textContent='Saving...';es.className='save-status saving';
  try{
    await updateDocInFirebase(currentEditDocId,{body,bodyText,editedBy:currentUser.username,editedAt:new Date().toISOString()});
    const local=allDocs.find(d=>d.fbId===currentEditDocId);
    if(local){local.body=body;local.bodyText=bodyText;local.editedBy=currentUser.username;local.editedAt=new Date().toISOString();}
    es.textContent='✓ Updated';es.className='save-status saved';
    toast('Document updated in Firebase!','success');
    addActivity(`<strong>${currentUser.name}</strong> edited "<em>${local?.title||'doc'}</em>"`,'✏️');
    editModified=false;
    const em=document.getElementById('e-modified');if(em)em.textContent='Saved';
    setTimeout(()=>{es.textContent='Ready';es.className='save-status';},3000);
    renderDocs();
  }catch(e){es.textContent='Update failed';es.className='save-status';toast('Error: '+e.message,'error');}
}

async function deleteEditDoc(){
  if(!currentEditDocId)return;
  const doc=allDocs.find(d=>d.fbId===currentEditDocId);
  if(!confirm(`Delete "${doc?.title||'this document'}"? This cannot be undone.`))return;
  try{
    await deleteDocFromFirebase(currentEditDocId);
    allDocs=allDocs.filter(d=>d.fbId!==currentEditDocId);
    currentEditDocId=null;
    document.getElementById('e-editor').innerHTML='';
    document.getElementById('e-editor').contentEditable='false';
    document.getElementById('e-save-btn').disabled=true;
    document.getElementById('e-del-btn').disabled=true;
    document.getElementById('e-doc-name').textContent='No document loaded';
    updateCounters();renderDocs();renderEditList();
    toast('Document deleted','error');
    addActivity(`<strong>${currentUser.name}</strong> deleted a document`,'🗑️');
  }catch(e){toast('Delete failed: '+e.message,'error');}
}

async function quickDelete(fbId){
  const doc=allDocs.find(d=>d.fbId===fbId);
  if(!confirm(`Delete "${doc?.title||'this document'}"?`))return;
  try{
    await deleteDocFromFirebase(fbId);
    allDocs=allDocs.filter(d=>d.fbId!==fbId);
    if(currentEditDocId===fbId){currentEditDocId=null;document.getElementById('e-editor').innerHTML='';}
    updateCounters();renderDocs();renderEditList();
    toast('Deleted','error');
  }catch(e){toast('Error: '+e.message,'error');}
}

/* ════ DOCS PANEL ════ */
function renderDocs(){
  const grid=document.getElementById('docsGrid');if(!grid)return;
  const q=(document.getElementById('searchInput')?.value||'').toLowerCase();
  let filtered=allDocs.filter(d=>!q||d.title?.toLowerCase().includes(q)||d.bodyText?.toLowerCase().includes(q));
  if(currentDocFilter!=='all')filtered=filtered.filter(d=>d.type===currentDocFilter);
  if(!filtered.length){
    grid.innerHTML=`<div class="empty-state"><div class="empty-icon">📄</div><div class="empty-title">NO DOCUMENTS</div><div class="empty-desc">${q?'No results for "'+q+'"':'Write or edit content and save to Firebase'}</div></div>`;
    return;
  }
  grid.innerHTML=filtered.map(d=>`
    <div class="doc-card" onclick="viewDoc('${d.fbId}')">
      <div class="doc-tag ${d.type==='edit'?'dt-edit':'dt-write'}">${d.type==='edit'?'✏ EDITED':'✍ WRITTEN'}${d.tag?' · '+d.tag.toUpperCase():''}</div>
      <div class="doc-title-text">${d.title||'Untitled'}</div>
      <div class="doc-preview">${d.bodyText||'No preview available'}</div>
      <div class="doc-card-meta">
        <span class="doc-author">By ${d.authorName||d.author}</span>
        <span class="doc-date">${fmtDate(d.timestamp)}</span>
      </div>
      <div class="doc-actions">
        <button class="doc-action-btn dab-view" onclick="event.stopPropagation();viewDoc('${d.fbId}')">VIEW</button>
        ${PERMS[currentUser?.role||'viewer'].edit?`<button class="doc-action-btn dab-del" onclick="event.stopPropagation();quickDelete('${d.fbId}')">DELETE</button>`:''}
      </div>
    </div>`).join('');
}

function filterDocs(){renderDocs();}
function setFilter(el,type){
  currentDocFilter=type;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  renderDocs();
}

/* ════ DOC VIEWER ════ */
function viewDoc(fbId){
  const doc=allDocs.find(d=>d.fbId===fbId);if(!doc)return;
  document.getElementById('dv-title').textContent=doc.title||'Untitled Document';
  document.getElementById('dv-meta2').textContent=`By ${doc.authorName||doc.author} · ${fmtDate(doc.timestamp)}${doc.editedAt?' · Edited: '+fmtDate(doc.editedAt):''}`;
  document.getElementById('dv-body').innerHTML=doc.body||doc.bodyText||'No content';
  document.getElementById('dv-footer-meta').textContent=`ID: ${doc.fbId} · ${doc.tag?'Tag: '+doc.tag.toUpperCase()+' · ':''}Type: ${doc.type}`;
  document.getElementById('docViewer').classList.add('open');
}
function closeViewer(){document.getElementById('docViewer').classList.remove('open');}

function previewDoc(mode){
  const title=mode==='write'?document.getElementById('w-title').value:'Editing';
  const body=document.getElementById(mode==='write'?'w-editor':'e-editor').innerHTML;
  const doc={fbId:'preview',title:title||'Preview',body,authorName:currentUser?.name,timestamp:new Date().toISOString()};
  document.getElementById('dv-title').textContent=doc.title;
  document.getElementById('dv-meta2').textContent='Preview only — not saved';
  document.getElementById('dv-body').innerHTML=body;
  document.getElementById('dv-footer-meta').textContent='PREVIEW MODE';
  document.getElementById('docViewer').classList.add('open');
}

/* ════ ACTIVITY ════ */
function renderActivity(){
  const feed=document.getElementById('activityFeed');if(!feed)return;
  if(!activityLog.length){feed.innerHTML='<li style="color:var(--txt3);font-size:11px;font-family:var(--f3);padding:10px 0">No activity yet.</li>';return;}
  feed.innerHTML=activityLog.slice(0,8).map(a=>`
    <li class="activity-item">
      <div class="act-icon" style="background:rgba(0,102,255,.08);border:1px solid rgba(0,102,255,.12)">${a.icon}</div>
      <div class="act-content">
        <div class="act-text">${a.text}</div>
        <div class="act-time">${fmtDate(a.time)}</div>
      </div>
    </li>`).join('');
}

/* ════ ADMIN ════ */
function adminHTML(){
  return `<div class="users-wrap"><table class="u-tbl">
<thead><tr><th>User</th><th>Username</th><th>Current Role</th><th>Assign Role</th></tr></thead>
<tbody id="usersBody"></tbody></table></div>
<div class="admin-note" style="margin-top:12px">
<div class="admin-note-text"><strong>FIREBASE SYNC:</strong> All role changes save instantly to Firestore. Changes are visible across all devices in real-time. You cannot change your own role.</div>
</div>`;
}

function renderUsersTable(){
  const body=document.getElementById('usersBody');if(!body)return;
  body.innerHTML=userList.map(u=>{
    const self=u.username===currentUser.username;
    return `<tr>
<td><div class="u-info-cell">
  <div class="u-av-sm" style="background:${u.bg};color:${u.color};border:1px solid ${u.color}33">${u.initials}</div>
  <div>
    <div class="u-uname">${u.name.toUpperCase()}${self?'<span class="you-tag">YOU</span>':''}</div>
    <div class="u-fullname">${u.username}</div>
  </div>
</div></td>
<td style="font-family:var(--f3);font-size:10px;color:var(--txt3)">@${u.username}</td>
<td><div class="rpill ${PILL_CLS[u.role]}" style="display:inline-flex"><div class="rpill-dot" style="background:${u.color}"></div>${ROLE_LABEL[u.role]}</div></td>
<td><select class="role-sel" onchange="changeRole(${u.id},this.value)" ${self?'disabled':''}>
  <option value="admin" ${u.role==='admin'?'selected':''}>ADMINISTRATOR</option>
  <option value="editor" ${u.role==='editor'?'selected':''}>EDITOR</option>
  <option value="viewer" ${u.role==='viewer'?'selected':''}>VIEWER</option>
</select></td></tr>`;
  }).join('');
}

async function changeRole(uid,role){
  const u=userList.find(x=>x.id===uid);if(!u)return;
  u.role=role;renderUsersTable();
  await saveUserToFirebase(u);
  toast(`${u.name} → ${ROLE_LABEL[role]}  (synced)`,'success');
  addActivity(`<strong>${currentUser.name}</strong> changed ${u.name}'s role to ${ROLE_LABEL[role]}`,'🔑');
}

function deniedHTML(msg){
  return `<div class="card"><div class="access-denied">
<div class="denied-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--rd)" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
<div class="denied-title">ACCESS DENIED</div>
<div class="denied-desc">${msg}. Contact your system administrator.</div>
</div></div>`;
}

/* ════ HELPERS ════ */
function fmtDate(ts){
  if(!ts)return 'Unknown';
  const d=new Date(ts);
  return d.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
}

// Login card tilt
const lc=document.querySelector('.login-card');
document.querySelector('#loginPage')?.addEventListener('mousemove',e=>{
  const r=lc.getBoundingClientRect(),cx=r.left+r.width/2,cy=r.top+r.height/2;
  lc.style.transform=`perspective(800px) rotateY(${(e.clientX-cx)/r.width*8}deg) rotateX(${-(e.clientY-cy)/r.height*8}deg)`;
});
document.querySelector('#loginPage')?.addEventListener('mouseleave',()=>{lc.style.transform='';});

// Click ripple
document.addEventListener('click',e=>{
  const r=document.createElement('div');
  r.style.cssText=`position:fixed;left:${e.clientX}px;top:${e.clientY}px;width:50px;height:50px;border-radius:50%;border:1px solid rgba(0,102,255,.5);transform:translate(-50%,-50%) scale(0);animation:rip .7s ease forwards;z-index:5;pointer-events:none`;
  const s=document.createElement('style');s.textContent='@keyframes rip{to{transform:translate(-50%,-50%) scale(1);opacity:0;border-width:0}}';
  document.head.appendChild(s);document.body.appendChild(r);setTimeout(()=>{r.remove();s.remove();},800);
});
</script>
</body>
