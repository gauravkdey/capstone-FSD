<script>
/* ═══ THREE.JS 3D BACKGROUND ═══ */
(function(){
  const cv=document.getElementById('threeCanvas');
  const scene=new THREE.Scene();
  const camera=new THREE.PerspectiveCamera(60,window.innerWidth/window.innerHeight,.1,1000);
  camera.position.set(0,0,30);
  const renderer=new THREE.WebGLRenderer({canvas:cv,antialias:true,alpha:true});
  renderer.setSize(window.innerWidth,window.innerHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.setClearColor(0x000000,0);

  /* Torus knot - main centerpiece */
  const torusGeo=new THREE.TorusKnotGeometry(8,0.3,200,20,3,5);
  const torusMat=new THREE.MeshBasicMaterial({color:0x0044ff,wireframe:true,transparent:true,opacity:.08});
  const torus=new THREE.Mesh(torusGeo,torusMat);
  scene.add(torus);

  /* Outer sphere wireframe */
  const sphereGeo=new THREE.IcosahedronGeometry(18,2);
  const sphereMat=new THREE.MeshBasicMaterial({color:0x0033aa,wireframe:true,transparent:true,opacity:.04});
  const sphere=new THREE.Mesh(sphereGeo,sphereMat);
  scene.add(sphere);

  /* Floating hexagons */
  const hexGroup=new THREE.Group();
  scene.add(hexGroup);
  for(let i=0;i<20;i++){
    const ring=new THREE.RingGeometry(.3+Math.random()*.8,(.3+Math.random()*.8)+.06,6);
    const mat=new THREE.MeshBasicMaterial({color:i%3===0?0x0066ff:i%3===1?0x7c2dff:0x00e5ff,side:THREE.DoubleSide,transparent:true,opacity:Math.random()*.15+.05});
    const mesh=new THREE.Mesh(ring,mat);
    mesh.position.set((Math.random()-.5)*50,(Math.random()-.5)*30,(Math.random()-.5)*20);
    mesh.rotation.set(Math.random()*Math.PI,Math.random()*Math.PI,Math.random()*Math.PI);
    mesh.userData={vx:(Math.random()-.5)*.01,vy:(Math.random()-.5)*.008,vz:(Math.random()-.5)*.005,rx:Math.random()*.008,ry:Math.random()*.005};
    hexGroup.add(mesh);
  }

  /* Particles */
  const partGeo=new THREE.BufferGeometry();
  const n=1800;
  const pos=new Float32Array(n*3);
  const col=new Float32Array(n*3);
  for(let i=0;i<n;i++){
    pos[i*3]=(Math.random()-.5)*120;pos[i*3+1]=(Math.random()-.5)*80;pos[i*3+2]=(Math.random()-.5)*60;
    const c=Math.random();
    if(c<.5){col[i*3]=0;col[i*3+1]=.3;col[i*3+2]=1}
    else if(c<.8){col[i*3]=.5;col[i*3+1]=.1;col[i*3+2]=1}
    else{col[i*3]=0;col[i*3+1]=.9;col[i*3+2]=1}
  }
  partGeo.setAttribute('position',new THREE.BufferAttribute(pos,3));
  partGeo.setAttribute('color',new THREE.BufferAttribute(col,3));
  const partMat=new THREE.PointsMaterial({size:.12,vertexColors:true,transparent:true,opacity:.6,sizeAttenuation:true});
  const parts=new THREE.Points(partGeo,partMat);
  scene.add(parts);

  /* Connection lines (dynamic) */
  const lineGroup=new THREE.Group();
  scene.add(lineGroup);
  function buildLines(){
    while(lineGroup.children.length)lineGroup.remove(lineGroup.children[0]);
    for(let i=0;i<12;i++){
      const pts=[new THREE.Vector3((Math.random()-.5)*40,(Math.random()-.5)*25,(Math.random()-.5)*15),new THREE.Vector3((Math.random()-.5)*40,(Math.random()-.5)*25,(Math.random()-.5)*15)];
      const geo=new THREE.BufferGeometry().setFromPoints(pts);
      const mat=new THREE.LineBasicMaterial({color:0x0044ff,transparent:true,opacity:Math.random()*.08+.02});
      lineGroup.add(new THREE.Line(geo,mat));
    }
  }
  buildLines();setInterval(buildLines,4000);

  let mouseX=0,mouseY=0;
  document.addEventListener('mousemove',e=>{mouseX=(e.clientX/window.innerWidth-.5)*2;mouseY=(e.clientY/window.innerHeight-.5)*2});
  window.addEventListener('resize',()=>{renderer.setSize(window.innerWidth,window.innerHeight);camera.aspect=window.innerWidth/window.innerHeight;camera.updateProjectionMatrix()});

  let t=0;
  function animate(){
    requestAnimationFrame(animate);t+=.005;
    torus.rotation.x=t*.4;torus.rotation.y=t*.3;
    sphere.rotation.y=t*.1;sphere.rotation.z=t*.05;
    parts.rotation.y=t*.02;parts.rotation.x=t*.01;
    hexGroup.children.forEach(h=>{
      h.position.x+=h.userData.vx;h.position.y+=h.userData.vy;h.position.z+=h.userData.vz;
      h.rotation.x+=h.userData.rx;h.rotation.y+=h.userData.ry;
      if(Math.abs(h.position.x)>30){h.userData.vx*=-1}if(Math.abs(h.position.y)>20){h.userData.vy*=-1}if(Math.abs(h.position.z)>15){h.userData.vz*=-1}
    });
    camera.position.x+=(mouseX*3-camera.position.x)*.04;
    camera.position.y+=(-mouseY*2-camera.position.y)*.04;
    camera.lookAt(0,0,0);
    renderer.render(scene,camera);
  }
  animate();
})();

/* ═══ DATA STREAM CANVAS ═══ */
(function(){
  const cv=document.getElementById('dataCanvas');
  const cx=cv.getContext('2d');
  let W,H;
  const resize=()=>{W=cv.width=window.innerWidth;H=cv.height=window.innerHeight};
  resize();window.addEventListener('resize',resize);
  const cols=[
    {r:0,g:102,b:255},
    {r:124,g:45,b:255},
    {r:0,g:229,b:255},
    {r:0,g:255,b:136}
  ];
  const streams=[];
  for(let i=0;i<20;i++){
    const c=cols[Math.floor(Math.random()*cols.length)];
    streams.push({x:Math.random()*window.innerWidth,y:Math.random()*H,speed:Math.random()*1.5+.5,opacity:Math.random()*.3+.05,len:Math.random()*60+20,r:c.r,g:c.g,b:c.b,dir:Math.random()<.5?1:-1});
  }
  function frame(){
    cx.clearRect(0,0,W,H);
    streams.forEach(s=>{
      cx.beginPath();
      cx.moveTo(s.x,s.y);
      cx.lineTo(s.x,s.y+s.len*s.dir);
      cx.strokeStyle=`rgba(${s.r},${s.g},${s.b},${s.opacity})`;
      cx.lineWidth=.8;
      cx.stroke();
      s.y+=s.speed*s.dir;
      if(s.y<-100||s.y>H+100){s.y=s.dir>0?-10:H+10;s.x=Math.random()*W}
    });
    requestAnimationFrame(frame);
  }
  frame();
})();

