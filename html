function saveContent(id){
  const fb=document.getElementById('saveFb_'+id);
  fb.classList.add('show');showToast('Document committed to ledger');
  setTimeout(()=>fb.classList.remove('show'),2600);
}

function deniedHTML(msg){
  return `<div class="card"><div class="access-denied">
<div class="denied-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--rd)" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
<div class="denied-title">ACCESS_DENIED</div>
<div class="denied-desc">${msg}. Contact system administrator to request elevated clearance.</div>
</div></div>`;
}

function adminHTML(){
  return `<div class="users-table-wrap"><table class="users-tbl">
<thead><tr><th>USER</th><th>ID</th><th>CURRENT_ROLE</th><th>ASSIGN_ROLE</th></tr></thead>
<tbody id="usersBody"></tbody></table></div>
<div class="admin-info-box">
<div class="admin-info-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--nb2)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div>
<div class="admin-info-text"><strong>ADMIN_ONLY:</strong> Role changes take effect immediately. Cannot modify own access level. Three tiers: <strong>ADMIN</strong> (full), <strong>EDITOR</strong> (write+view), <strong>VIEWER</strong> (view only).</div>
</div>`;
}

function renderUsersTable(){
  const body=document.getElementById('usersBody');if(!body)return;
  body.innerHTML=userList.map(u=>{
    const self=u.username===currentUser.username;
    return `<tr>
<td><div class="u-info">
  <div class="user-avatar" style="background:${u.bg};color:${u.color};width:34px;height:34px;font-size:10px;font-family:var(--f1);font-weight:700;border-radius:2px;display:flex;align-items:center;justify-content:center;border:1px solid ${u.color}33">${u.initials}</div>
  <div class="u-name">${u.name.toUpperCase()}${self?'<span class="you-badge">YOU</span>':''}</div>
</div></td>
<td style="color:var(--txt3);font-size:11px;font-family:var(--f3)">${u.username}</td>
<td><div class="role-pill ${PILL_CLASS[u.role]}" style="display:inline-flex"><div class="role-pill-dot" style="background:${u.color};box-shadow:0 0 6px ${u.color}"></div><span>${ROLE_LABEL[u.role]}</span></div></td>
<td><select class="role-select" onchange="changeRole(${u.id},this.value)" ${self?'disabled':''}>
  <option value="admin" ${u.role==='admin'?'selected':''}>ADMINISTRATOR</option>
  <option value="editor" ${u.role==='editor'?'selected':''}>EDITOR</option>
  <option value="viewer" ${u.role==='viewer'?'selected':''}>VIEWER</option>
</select></td></tr>`;
  }).join('');
}

function changeRole(uid,role){
  const u=userList.find(x=>x.id===uid);if(!u)return;
  u.role=role;renderUsersTable();showToast(u.name+' → '+ROLE_LABEL[role]);
}

function resetNav(){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelector('[data-panel="dashboard"]').classList.add('active');
  document.getElementById('panel-dashboard').classList.add('active');
}

function navClick(el){
  if(el.classList.contains('locked')){showToast('CLEARANCE_DENIED: Insufficient privileges');return}
  switchPanel(el);
}

function switchPanel(el){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  const panel=document.getElementById('panel-'+el.dataset.panel);
  if(panel)panel.classList.add('active');
  if(el.dataset.panel==='admin')renderUsersTable();
}

/* ═══ LOGIN CARD MOUSE TILT ═══ */
const loginCard=document.querySelector('.login-card');
if(loginCard){
  document.querySelector('#loginPage').addEventListener('mousemove',e=>{
    const r=loginCard.getBoundingClientRect();
    const cx=(r.left+r.width/2),cy=(r.top+r.height/2);
    const dx=(e.clientX-cx)/r.width*10,dy=(e.clientY-cy)/r.height*10;
    loginCard.style.transform=`perspective(800px) rotateY(${dx}deg) rotateX(${-dy}deg)`;
  });
  document.querySelector('#loginPage').addEventListener('mouseleave',()=>{loginCard.style.transform=''});
}
</script>
</body>
</html>
