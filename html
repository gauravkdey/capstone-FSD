.doc-action-btn{padding:4px 10px;border-radius:2px;font-size:9px;font-weight:700;font-family:var(--f1);cursor:pointer;transition:all .15s;border:1px solid;letter-spacing:.5px}
.dab-view{background:rgba(0,102,255,.08);border-color:rgba(0,102,255,.2);color:var(--nb2)}
